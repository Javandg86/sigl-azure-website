{
  "routes": [
    {
      "route": "/sigl-dashboard*",
      "allowedRoles": ["sigl_admin"]
    },
    {
      "route": "/api/dashboard-leads",
      "allowedRoles": ["sigl_admin"]
    }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad",
      "statusCode": 302
    }
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/*.{css,scss,js,png,gif,ico,jpg,svg}"]
  }
}
